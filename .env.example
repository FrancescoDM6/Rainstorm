# LLM Provider: 'ollama', 'anthropic', 'gemini', or 'openai'
LLM_PROVIDER=ollama

# Ollama (default - easiest local setup)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Anthropic (cloud)
# ANTHROPIC_API_KEY=your-api-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini (cloud)
# GEMINI_API_KEY=your-api-key-here
# GEMINI_MODEL=gemini-2.0-flash

# OpenAI-compatible (LM Studio, LocalAI, vLLM, etc.)
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_MODEL=local-model
# OPENAI_API_KEY=not-needed-for-local

# Rate limiting (cloud providers only, ollama is always unlimited)
# Max requests per minute. 0 = unlimited. Default: 0
# RATE_LIMIT_RPM=10
